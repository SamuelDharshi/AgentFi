{
  "name": "backend",
  "version": "1.0.0",
  "description": "AgentFi backend services",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build && node dist/server.js",
    "dev:watch": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "orchestrate:headless": "tsx src/orchestration/headlessLoop.ts",
    "test:e2e-live": "jest --config jest.e2e.config.cjs --runInBand",
    "test:e2e-live:verbose": "jest --config jest.e2e.config.cjs --runInBand --verbose",
    "test:live:all": "powershell -ExecutionPolicy Bypass -File ../scripts/run-live-e2e.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hashgraph/sdk": "^2.80.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "openai": "^6.27.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
