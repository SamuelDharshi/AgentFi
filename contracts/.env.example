# ─── contracts/.env  (copy to contracts/.env and fill in real values) ────────
# Never commit the real .env to source control.

# ── Hedera network ─────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet

# ── Operator account (pays all transaction fees) ───────────────────────────────
# Create a testnet account at https://portal.hedera.com then fund it via the faucet.
HEDERA_OPERATOR_ID=0.0.8149406
# ED25519 private key — used for native Hedera transactions (HTS, topic, transfer)
HEDERA_OPERATOR_KEY=302e020100300506032b65700422042095ebf66b31add3876efbb4982255b863a2d8e6658b685f4ca5dc73f5a1b634a0
# ECDSA secp256k1 private key — used for EVM contract deployment via ethers.js
# This MUST be the ECDSA key linked to the same account as HEDERA_OPERATOR_ID.
# In Hedera Portal you can add an ECDSA alias to an existing account.
HEDERA_OPERATOR_EVM_KEY=0x78558871c1a7cfe66d3ffc22aab4143a839e1d332d19db375baedf959445c681
# ── Hedera JSON-RPC relay ──────────────────────────────────────────────────────
# Hashio public relay — no account needed for testnet
HEDERA_JSON_RPC_URL=https://testnet.hashio.io/api

# ── Market-agent account ───────────────────────────────────────────────────────
# Must be a separate testnet account (not the operator).
# EVM address: convert 0.0.X → 0x{padded-hex} or look up on https://hashscan.io
MARKET_AGENT_ACCOUNT_ID=0.0.8150387
MARKET_AGENT_EVM_ADDRESS=0x6d841f79e83e4274ef4b6db14e557e8aae244f5e

# ── User account ───────────────────────────────────────────────────────────────
USER_ACCOUNT_ID=0.0.8156570
USER_EVM_ADDRESS=0x2e842fa5de7fa61b3dc8748e00c540848d31e8f8

# ── Optional: re-use an existing HTS token instead of creating a new one ──────
# Leave blank to create a new AUSDC token on first deploy.
HTS_TOKEN_ID=
