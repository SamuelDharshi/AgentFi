# Monorepo dependency directories
**/node_modules/

# Build outputs
**/dist/
**/build/
**/.next/
**/out/
**/coverage/

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep env templates tracked
!.env.example
!**/.env.example

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Package manager/system artifacts
**/.pnp
**/.pnp.*
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/versions

# TypeScript
**/*.tsbuildinfo

# Vercel
**/.vercel/
