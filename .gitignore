# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Secrets — NEVER commit real keys or credentials ─────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow .env.example files (safe placeholder templates)
!.env.example
# Local file currently containing real keys — keep out of git
contracts/.env.example

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
.next/

# ─── Solidity compiler output ─────────────────────────────────────────────────
contracts/out/
contracts/dist/

# ─── Deployment artifacts (contain live contract addresses) ──────────────────
contracts/deployed.json

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Testing / Coverage ───────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── OS generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── Vercel / deployment ──────────────────────────────────────────────────────
.vercel

